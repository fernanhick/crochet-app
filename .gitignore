# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Next.js (crochet-admin) ───────────────────────────────────────────────────
crochet-admin/.next/
crochet-admin/out/
crochet-admin/build/

# ── Expo / React Native (crochet-blueprint) ───────────────────────────────────
crochet-blueprint/.expo/
crochet-blueprint/dist/
crochet-blueprint/web-build/

# Android build outputs
crochet-blueprint/android/build/
crochet-blueprint/android/app/build/
crochet-blueprint/android/.gradle/
crochet-blueprint/android/local.properties

# iOS build outputs
crochet-blueprint/ios/build/
crochet-blueprint/ios/Pods/
crochet-blueprint/ios/*.xcworkspace/
crochet-blueprint/ios/*.xcuserstate

# ── Convex generated (regenerated by `npx convex dev`) ───────────────────────
# Keep _generated committed so admin app stays self-contained without running convex dev
# (Remove this comment and uncomment below if you prefer to generate locally only)
# crochet-blueprint/convex/_generated/
# crochet-admin/convex/_generated/

# ── Misc ──────────────────────────────────────────────────────────────────────
.DS_Store
*.pem
.vercel
*.tsbuildinfo
next-env.d.ts
