{
  "name": "crochet-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run sync-convex && next dev",
    "build": "npm run sync-convex && next build",
    "start": "next start",
    "lint": "next lint",
    "sync-convex": "node -e \"const{cpSync}=require('fs');cpSync('../crochet-blueprint/convex/_generated','./convex/_generated',{recursive:true,force:true});console.log('Convex types synced')\""
  },
  "dependencies": {
    "@clerk/nextjs": "^6.0.0",
    "convex": "^1.32.0",
    "next": "^15.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  }
}
